# ============================================
# Eranova Docs — Environment Variables
# ============================================
# Copy this file to .env.local for local dev
# cp .env.example .env.local

# Site Configuration
URL=https://docs.eranova-workforge.dev
BASE_URL=/

# GitHub Pages Deployment
ORGANIZATION_NAME=eranova-workforge
PROJECT_NAME=eranova-docs
DEPLOYMENT_BRANCH=gh-pages

# Git (for deploy command)
GIT_USER=your-github-username
USE_SSH=false

# Analytics (optional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# ALGOLIA_APP_ID=your-algolia-app-id
# ALGOLIA_API_KEY=your-algolia-search-key
# ALGOLIA_INDEX_NAME=eranova-docs

# Custom Domain (optional)
# CUSTOM_DOMAIN=docs.eranova-workforge.dev
